module voting_machine(
    input clk,
    input reset,
    input [1:0] voter_id,
    input vote_A,
    input vote_B,
    output reg [3:0] count_A,
    output reg [3:0] count_B,
    output reg duplicate
);

reg [3:0] voted;   

always @(posedge clk or posedge reset)
begin
    if(reset)
    begin
        count_A <= 0;
        count_B <= 0;
        voted <= 4'b0000;
        duplicate <= 0;
    end

    else
    begin

        if(voted[voter_id] == 1)
        begin
            duplicate <= 1;
        end

        else
        begin
            duplicate <= 0;

            if(vote_A)
                count_A <= count_A + 1;

            else if(vote_B)
                count_B <= count_B + 1;

            voted[voter_id] <= 1;
        end
    end
end

endmodule
